---
import Header from '../components/Header.astro';
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'ملاحظات المبرمج' } = Astro.props;
const pageTitle = title === 'ملاحظات المبرمج' ? title : `${title} — ملاحظات المبرمج`;
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="ملاحظات و دروس في البرمجة و الأمن السيبراني باللغة العربية — حديقة معرفة شخصية لتتبع التعلم و مشاركته" />
  <title>{pageTitle}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700;1,400;1,700&family=Tajawal:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <Header />
  <slot />
</body>
</html>
