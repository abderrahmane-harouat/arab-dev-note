---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OutdatedBanner from '../../components/OutdatedBanner.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map(note => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);
const {
  title, domain, tags, created, updated,
  outdated, outdatedReason, outdatedAlternative,
  stage, history, heroImage
} = note.data;

const stageLabels: Record<string, string> = {
  seedling: '🌱 بذرة',
  budding: '🌿 نامية',
  evergreen: '🌳 مكتملة',
};
---

<BaseLayout title={title}>
  <main class="note-page content-area">
    <article>
      <div class="note-header">
        <div class="note-badges">
          <span class="domain-badge">{domain}</span>
          <span class={`stage-badge ${stage}`}>{stageLabels[stage] || stageLabels.budding}</span>
          {outdated && <span class="outdated-badge">قديم</span>}
        </div>

        {heroImage && (
          <div class="note-icon">
            <img src={heroImage} alt="" width="48" height="48" />
          </div>
        )}

        <h1 class="note-title">{title}</h1>

        <div class="note-dates">
          <span>أُنشئ: {created}</span>
          <span class="sep">|</span>
          <span>آخر تحديث: {updated}</span>
        </div>

        {tags && tags.length > 0 && (
          <div class="note-tags">
            {tags.map(tag => (
              <span class="tag">#{tag}</span>
            ))}
          </div>
        )}
      </div>

      {outdated && (
        <OutdatedBanner reason={outdatedReason} alternative={outdatedAlternative} />
      )}

      <div class="prose">
        <Content />
      </div>

      {history && history.length > 0 && (
        <section class="history-section">
          <h2 class="history-title">سجل التغييرات</h2>
          <div class="history-timeline">
            {history.map(entry => (
              <div class="history-entry">
                <div class="history-dot"></div>
                <div class="history-body">
                  <span class="history-date">{entry.date}</span>
                  <span class="history-note">{entry.note}</span>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <a href="/" class="back-link">← العودة إلى الملاحظات</a>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .note-page {
    padding-top: 2.5rem;
    padding-bottom: 4rem;
    max-width: 780px;
  }

  .note-header {
    margin-bottom: 2rem;
  }

  .note-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .domain-badge {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.2rem 0.65rem;
    border-radius: var(--radius-pill);
  }

  .stage-badge {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-pill);
    font-weight: 500;
  }

  .stage-badge.seedling { color: var(--seedling); background: rgba(22, 163, 74, 0.08); }
  .stage-badge.budding { color: var(--budding); background: var(--accent-soft); }
  .stage-badge.evergreen { color: var(--evergreen); background: rgba(37, 99, 235, 0.08); }

  .outdated-badge {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--outdated-text);
    background: var(--outdated-bg);
    padding: 0.2rem 0.55rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--outdated-border);
  }

  .note-icon {
    width: 48px;
    height: 48px;
    margin-bottom: 1rem;
    border-radius: var(--radius);
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    padding: 0.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .note-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .note-title {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 0.75rem;
  }

  .note-dates {
    display: flex;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-variant-numeric: tabular-nums;
  }

  .sep { opacity: 0.3; }

  .note-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }

  .tag {
    font-size: 0.78rem;
    color: var(--text-secondary);
    background: var(--bg-surface-hover);
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius);
    font-weight: 400;
  }

  /* ── History ── */

  .history-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .history-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    margin-bottom: 1.25rem;
    font-weight: 700;
  }

  .history-timeline {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-right: 1rem;
    border-right: 2px solid var(--border-subtle);
  }

  .history-entry {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    position: relative;
  }

  .history-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    margin-top: 0.5rem;
    position: relative;
    right: calc(-1rem - 5px);
  }

  .history-body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .history-date {
    font-size: 0.82rem;
    color: var(--accent);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .history-note {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .back-link {
    display: inline-block;
    margin-top: 3rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: color 0.2s;
  }

  .back-link:hover { color: var(--accent); }

  @media (max-width: 640px) {
    .note-title { font-size: 1.7rem; }
    .note-dates { flex-direction: column; gap: 0.2rem; }
    .sep { display: none; }
  }
</style>
