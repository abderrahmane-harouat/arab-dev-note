---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import NoteCard from '../components/NoteCard.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes');

const domainOrder = ['أساسيات', 'أُطر ومكتبات', 'أدوات', 'تصميم', 'الأمن السيبراني'];

const domainCounts: Record<string, number> = {};
allNotes.forEach(note => {
  const d = note.data.domain;
  domainCounts[d] = (domainCounts[d] || 0) + 1;
});

const activeDomains = domainOrder.filter(d => domainCounts[d]);

allNotes.sort((a, b) => b.data.updated.localeCompare(a.data.updated));
---

<BaseLayout>
  <Hero />

  <main class="content-area" id="notes">
    <div class="section-header">
      <h2 class="section-title">الملاحظات</h2>
      <span class="note-count">{allNotes.length} ملاحظة</span>
    </div>

    <div class="search-box">
      <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8" />
        <path d="m21 21-4.3-4.3" />
      </svg>
      <input
        type="search"
        id="note-search"
        placeholder="ابحث في الملاحظات..."
        aria-label="ابحث في الملاحظات"
        autocomplete="off"
      />
    </div>

    <div class="filters" role="tablist" aria-label="تصفية حسب المجال">
      <button class="filter-btn active" data-domain="all" role="tab" aria-selected="true">
        الكل
        <span class="filter-count">{allNotes.length}</span>
      </button>
      {activeDomains.map(domain => (
        <button class="filter-btn" data-domain={domain} role="tab" aria-selected="false">
          {domain}
          <span class="filter-count">{domainCounts[domain]}</span>
        </button>
      ))}
    </div>

    <div class="notes-grid">
      {allNotes.map(note => (
        <NoteCard note={note} />
      ))}
    </div>

    <p class="no-results" id="no-results" hidden>لا توجد ملاحظات تطابق بحثك</p>
  </main>

  <Footer />
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.note-card');
  const searchInput = document.getElementById('note-search') as HTMLInputElement;
  const noResults = document.getElementById('no-results') as HTMLElement;

  let activeDomain = 'all';

  // توحيد النص العربي حتى لا يؤثر التشكيل أو أشكال الهمزة على نتائج البحث
  function normalize(text: string): string {
    return text
      .toLowerCase()
      .replace(/[ً-ْ]/g, '')
      .replace(/[أإآ]/g, 'ا')
      .replace(/ة/g, 'ه')
      .replace(/ى/g, 'ي');
  }

  function applyFilters() {
    const query = normalize(searchInput.value.trim());
    let visible = 0;

    cards.forEach(card => {
      const matchesDomain = activeDomain === 'all' || card.dataset.domain === activeDomain;
      const matchesQuery = !query || normalize(card.dataset.search || '').includes(query);
      const show = matchesDomain && matchesQuery;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    noResults.hidden = visible > 0;
  }

  searchInput.addEventListener('input', applyFilters);

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      activeDomain = btn.dataset.domain || 'all';
      buttons.forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      applyFilters();
    });
  });
</script>

<style>
  main { padding-bottom: 4rem; }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
  }

  .note-count {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .search-box {
    position: relative;
    margin-bottom: 1rem;
    max-width: 420px;
  }

  .search-icon {
    position: absolute;
    top: 50%;
    inset-inline-start: 0.9rem;
    transform: translateY(-50%);
    width: 1rem;
    height: 1rem;
    color: var(--text-secondary);
    pointer-events: none;
  }

  #note-search {
    width: 100%;
    padding: 0.55rem 2.5rem 0.55rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    background: var(--bg-surface);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.9rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  #note-search::placeholder {
    color: var(--text-secondary);
  }

  #note-search:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }

  .no-results {
    text-align: center;
    color: var(--text-secondary);
    padding: 3rem 0;
    font-size: 1rem;
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    background: transparent;
    color: var(--text-secondary);
    font-family: var(--font-body);
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
    font-weight: 500;
  }

  .filter-btn:hover {
    border-color: var(--accent-border);
    color: var(--accent);
  }

  .filter-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .filter-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  .filter-count {
    font-size: 0.72rem;
    opacity: 0.7;
    font-variant-numeric: tabular-nums;
  }

  .filter-btn.active .filter-count { opacity: 0.85; }

  .notes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  @media (max-width: 640px) {
    .notes-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
