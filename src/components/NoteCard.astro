---
interface Props {
  note: any;
}

const { note } = Astro.props;
const { title, domain, stage, created, updated, outdated, heroImage } = note.data;

const stageLabels: Record<string, string> = {
  seedling: '🌱 بذرة',
  budding: '🌿 نامية',
  evergreen: '🌳 مكتملة',
};

const wordCount = note.body ? note.body.trim().split(/\s+/).length : 0;
const readTime = Math.max(1, Math.ceil(wordCount / 200));

const now = new Date();
const updatedDate = new Date(updated);
const daysSinceUpdate = Math.floor((now.getTime() - updatedDate.getTime()) / (1000 * 60 * 60 * 24));
const isNew = daysSinceUpdate <= 30;
---

<a href={`/notes/${note.id}`} class="note-card" data-domain={domain}>
  <div class="card-top">
    <div class="card-top-right">
      <span class="domain-badge">{domain}</span>
      {isNew && <span class="new-badge">جديد</span>}
    </div>
    {outdated && <span class="outdated-tag">قديم</span>}
  </div>

  {heroImage && (
    <div class="card-icon">
      <img src={heroImage} alt="" loading="lazy" width="40" height="40" />
    </div>
  )}

  <h3 class="card-title">{title}</h3>

  <div class="card-bottom">
    <div class="card-meta">
      <span class={`stage-badge ${stage}`}>{stageLabels[stage] || stageLabels.budding}</span>
      <span class="read-time">⏱ {readTime} د</span>
    </div>
    <div class="card-dates">
      <span>أُنشئ {created}</span>
      <span class="date-sep">·</span>
      <span>تحديث {updated}</span>
    </div>
  </div>
</a>

<style>
  .note-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
    animation: fadeUp 0.4s ease-out both;
  }

  @media (prefers-reduced-motion: reduce) {
    .note-card { animation: none; }
  }

  .note-card:hover {
    border-color: var(--accent-border);
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.85rem;
  }

  .card-top-right {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .new-badge {
    font-size: 0.65rem;
    font-weight: 700;
    color: #fff;
    background: var(--seedling);
    padding: 0.12rem 0.5rem;
    border-radius: var(--radius-pill);
    letter-spacing: 0.02em;
  }

  .domain-badge {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-pill);
    letter-spacing: 0.01em;
  }

  .outdated-tag {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--outdated-text);
    background: var(--outdated-bg);
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--outdated-border);
  }

  .card-icon {
    width: 40px;
    height: 40px;
    margin-bottom: 0.75rem;
    border-radius: var(--radius);
    background: var(--bg-surface-hover);
    padding: 0.35rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.5;
    margin-bottom: 0.75rem;
    flex: 1;
  }

  .card-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: auto;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .read-time {
    font-size: 0.72rem;
    color: var(--text-secondary);
    font-variant-numeric: tabular-nums;
  }

  .stage-badge {
    font-size: 0.72rem;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-pill);
    font-weight: 500;
    width: fit-content;
  }

  .stage-badge.seedling { color: var(--seedling); background: rgba(22, 163, 74, 0.08); }
  .stage-badge.budding { color: var(--budding); background: var(--accent-soft); }
  .stage-badge.evergreen { color: var(--evergreen); background: rgba(37, 99, 235, 0.08); }

  .card-dates {
    display: flex;
    gap: 0.35rem;
    font-size: 0.75rem;
    color: var(--text-secondary);
    font-variant-numeric: tabular-nums;
  }

  .date-sep { opacity: 0.4; }
</style>
